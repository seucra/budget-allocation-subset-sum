import pytest
from api.main import placeholder_subset_sum

def test_subset_sum_basic():
    projects = [{"name": "P1", "cost": 100}, {"name": "P2", "cost": 200}]
    budget = 300
    indices, cost, time = placeholder_subset_sum(projects, budget)
    assert indices == [0, 1]
    assert cost == 300
    assert time >= 0

def test_subset_sum_empty():
    projects = []
    budget = 100
    indices, cost, time = placeholder_subset_sum(projects, budget)
    assert indices == []
    assert cost == 0
